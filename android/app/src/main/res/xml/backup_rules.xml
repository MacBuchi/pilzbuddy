<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup-Regeln ab Android 12 (API 31). Gesichert wird weiter, aber ohne:

  * FlutterSharedPreferences.xml — darin liegt ausschließlich der
    Supabase-Session-Token (`flutter.sb-<projekt>-auth-token`). Ein
    Auth-Credential hat weder in der Google-Cloud noch auf einem anderen
    Gerät etwas verloren. Die App legt sonst nichts in SharedPreferences ab,
    es geht also nichts weiter verloren.
  * offline_maps/ — die Bundesland-PMTiles sind 44 MB bis 1,7 GB groß und
    jederzeit neu ladbar. Auto-Backup hat ein Kontingent von 25 MB pro App;
    eine einzige Regionskarte sprengt es und lässt das Backup scheitern.
    Die Registry liegt im selben Ordner — `listInstalled()` überspringt
    Einträge ohne Datei, ein Teil-Restore ist also unkritisch.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="FlutterSharedPreferences.xml"/>
        <exclude domain="file" path="offline_maps"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="FlutterSharedPreferences.xml"/>
        <exclude domain="file" path="offline_maps"/>
    </device-transfer>
</data-extraction-rules>
